---
import { AUTHOR } from '../consts';
---

<div class="article-cta">
	<div class="article-cta__icon" aria-hidden="true">💬</div>
	<h3 class="article-cta__heading">Enjoyed this article?</h3>
	<p class="article-cta__text">
		I'm currently open to new roles — remote-first or international. If something resonated or you'd
		like to collaborate, I'd love to hear from you.
	</p>
	<div class="article-cta__actions">
		<a href={`mailto:${AUTHOR.email}`} class="article-cta__btn article-cta__btn--primary">
			Send an Email
		</a>
		<a
			href={AUTHOR.linkedin}
			target="_blank"
			rel="noopener"
			class="article-cta__btn article-cta__btn--secondary"
		>
			Connect on LinkedIn
		</a>
	</div>
</div>

<style>
	.article-cta {
		position: relative;
		background: color-mix(in srgb, var(--color-primary, #2563EB) 4%, transparent);
		border: 1px solid color-mix(in srgb, var(--color-primary, #2563EB) 18%, transparent);
		border-radius: 14px;
		padding: 2rem 1.75rem;
		margin: 3rem 0 0;
		text-align: center;
		overflow: hidden;
	}

	/* subtle decorative top accent bar */
	.article-cta::before {
		content: '';
		position: absolute;
		top: 0;
		left: 0;
		right: 0;
		height: 3px;
		background: var(--color-primary, #2563EB);
		border-radius: 14px 14px 0 0;
	}

	.article-cta__icon {
		font-size: 1.75rem;
		margin-bottom: 0.5rem;
		line-height: 1;
	}

	.article-cta__heading {
		font-size: 1.15rem;
		font-weight: 700;
		color: var(--color-text-primary, #111827);
		margin: 0 0 0.6rem;
		letter-spacing: -0.01em;
	}

	.article-cta__text {
		font-size: 0.925rem;
		color: var(--color-text-secondary, #6b7280);
		margin: 0 auto 1.5rem;
		line-height: 1.65;
		max-width: 440px;
	}

	.article-cta__actions {
		display: flex;
		gap: 0.75rem;
		justify-content: center;
		flex-wrap: wrap;
	}

	.article-cta__btn {
		display: inline-flex;
		align-items: center;
		padding: 0.6rem 1.35rem;
		border-radius: 8px;
		font-size: 0.875rem;
		font-weight: 600;
		text-decoration: none;
		transition: background 150ms ease, color 150ms ease, transform 150ms ease, box-shadow 150ms ease;
	}

	.article-cta__btn--primary {
		background: var(--color-primary, #2563EB);
		color: #fff;
		box-shadow: 0 2px 8px color-mix(in srgb, var(--color-primary, #2563EB) 35%, transparent);
	}

	.article-cta__btn--primary:hover {
		background: var(--color-primary-dark, #1D4ED8);
		transform: translateY(-1px);
		box-shadow: 0 4px 14px color-mix(in srgb, var(--color-primary, #2563EB) 40%, transparent);
		color: #fff;
	}

	.article-cta__btn--secondary {
		border: 1.5px solid color-mix(in srgb, var(--color-primary, #2563EB) 50%, transparent);
		color: var(--color-primary, #2563EB);
		background: color-mix(in srgb, var(--color-primary, #2563EB) 5%, transparent);
	}

	.article-cta__btn--secondary:hover {
		background: color-mix(in srgb, var(--color-primary, #2563EB) 10%, transparent);
		border-color: var(--color-primary, #2563EB);
		transform: translateY(-1px);
	}
</style>
