---
import { AUTHOR } from '../consts';

const today = new Date();
---

<footer>
	<div class="footer-inner">

		<div class="footer-col footer-col--brand">
			<span class="footer-name">{AUTHOR.name}</span>
			<span class="footer-tagline">Full Stack Engineer</span>
			<span class="footer-tagline">Open to remote &amp; international roles</span>
		</div>

		<div class="footer-col footer-col--nav">
			<p class="footer-col-label">Pages</p>
			<nav class="footer-links" aria-label="Footer navigation">
				<a href="/blog" class="footer-link">Blog</a>
				<a href="/topics" class="footer-link">Topics</a>
				<a href="/resume" class="footer-link">Resume</a>
				<a href="/contact" class="footer-link">Contact</a>
			</nav>
		</div>

		<div class="footer-col footer-col--utils">
			<p class="footer-col-label">Connect</p>
			<div class="footer-links">
				<a href={`mailto:${AUTHOR.email}`} class="footer-link">Email</a>
				<a href={AUTHOR.linkedin} target="_blank" rel="noopener" class="footer-link">LinkedIn</a>
				<a href={AUTHOR.github} target="_blank" rel="noopener" class="footer-link">GitHub</a>
			</div>
			<p class="footer-col-label footer-col-label--spaced">Feeds</p>
			<div class="footer-links">
				<a href="/rss.xml" class="footer-link footer-link--feed">
					<svg viewBox="0 0 24 24" width="13" height="13" fill="currentColor" aria-hidden="true">
						<path d="M6.18 15.64a2.18 2.18 0 0 1 2.18 2.18C8.36 19.01 7.38 20 6.18 20C4.98 20 4 19.01 4 17.82a2.18 2.18 0 0 1 2.18-2.18M4 4.44A15.56 15.56 0 0 1 19.56 20h-2.83A12.73 12.73 0 0 0 4 7.27V4.44m0 5.66a9.9 9.9 0 0 1 9.9 9.9h-2.83A7.07 7.07 0 0 0 4 12.93V10.1z"/>
					</svg>
					RSS Feed
				</a>
				<a href="/sitemap-index.xml" target="_blank" rel="noopener" class="footer-link footer-link--feed">
					<svg viewBox="0 0 24 24" width="13" height="13" fill="currentColor" aria-hidden="true">
						<path d="M3 3h8v8H3V3m2 2v4h4V5H5M13 3h8v8h-8V3m2 2v4h4V5h-4M3 13h8v8H3v-8m2 2v4h4v-4H5M18 13h2v2h-2v-2m-2 2h2v2h-2v-2m4 0h2v2h-2v-2m-2 2h2v2h-2v-2m2 2h2v2h-2v-2m-2-6h2v2h-2v-2m4 4h2v2h-2v-2"/>
					</svg>
					Sitemap
				</a>
			</div>
		</div>

	</div>

	<div class="footer-bottom">
		<p class="footer-copy">
			&copy; {today.getFullYear()} {AUTHOR.name} · Built with Astro
		</p>
	</div>
</footer>

<style>
	footer {
		border-top: 1px solid var(--color-border, #e5e7eb);
		background: var(--color-surface-raised, #f9fafb);
		margin-top: 4rem;
	}

	.footer-inner {
		max-width: 960px;
		margin: 0 auto;
		padding: 3rem 1.5rem 2rem;
		display: grid;
		grid-template-columns: 1.5fr 1fr 1fr;
		gap: 2.5rem;
	}

	/* ── Columns ── */
	.footer-col {
		display: flex;
		flex-direction: column;
	}

	.footer-col--brand {
		gap: 0.3rem;
	}

	.footer-name {
		font-size: 0.9375rem;
		font-weight: 700;
		color: var(--color-text-primary, #111827);
		line-height: 1.3;
	}

	.footer-tagline {
		font-size: 0.8rem;
		color: var(--color-text-tertiary, #9ca3af);
		line-height: 1.5;
	}

	/* ── Column labels ── */
	.footer-col-label {
		font-size: 0.7rem;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.08em;
		color: var(--color-text-tertiary, #9ca3af);
		margin: 0 0 0.6rem;
	}

	.footer-col-label--spaced {
		margin-top: 1.25rem;
	}

	/* ── Link lists ── */
	.footer-links {
		display: flex;
		flex-direction: column;
		gap: 0.4rem;
	}

	.footer-link {
		font-size: 0.8375rem;
		color: var(--color-text-secondary, #6b7280);
		text-decoration: none;
		transition: color 150ms ease;
		line-height: 1.5;
	}

	.footer-link:hover {
		color: var(--color-primary, #2563EB);
	}

	.footer-link--feed {
		display: inline-flex;
		align-items: center;
		gap: 0.35rem;
	}

	/* ── Bottom bar ── */
	.footer-bottom {
		border-top: 1px solid var(--color-border-subtle, #f3f4f6);
		padding: 1rem 1.5rem;
	}

	.footer-copy {
		max-width: 960px;
		margin: 0 auto;
		font-size: 0.75rem;
		color: var(--color-text-tertiary, #9ca3af);
	}

	/* ── Responsive ── */
	@media (max-width: 640px) {
		.footer-inner {
			grid-template-columns: 1fr;
			gap: 2rem;
			padding: 2.5rem 1.25rem 1.5rem;
		}
		.footer-bottom {
			padding: 1rem 1.25rem;
		}
	}
</style>
