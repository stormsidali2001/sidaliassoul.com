---
import { AUTHOR } from '../consts';
---

<div class="author-bio">
	<div class="author-bio__inner">
		<div class="author-bio__avatar-wrap">
			<img
				src={AUTHOR.avatar}
				alt={AUTHOR.name}
				class="author-bio__avatar"
				width="80"
				height="80"
			/>
		</div>
		<div class="author-bio__content">
			<p class="author-bio__eyebrow">Written by</p>
			<h3 class="author-bio__name">{AUTHOR.name}</h3>
			<p class="author-bio__text">{AUTHOR.bio}</p>
			<div class="author-bio__links">
				<a href={AUTHOR.linkedin} target="_blank" rel="noopener" class="author-bio__icon-btn" aria-label="LinkedIn">
					<svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor">
						<path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
					</svg>
					<span>LinkedIn</span>
				</a>
				<a href={AUTHOR.github} target="_blank" rel="noopener" class="author-bio__icon-btn" aria-label="GitHub">
					<svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor">
						<path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/>
					</svg>
					<span>GitHub</span>
				</a>
				<a href={`mailto:${AUTHOR.email}`} class="author-bio__icon-btn" aria-label="Email">
					<svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor">
						<path d="M20 4H4c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4-8 5-8-5V6l8 5 8-5v2z"/>
					</svg>
					<span>Email</span>
				</a>
			</div>
		</div>
	</div>
</div>

<style>
	.author-bio {
		margin: 3rem 0 2rem;
		border-radius: 14px;
		border: 1px solid var(--color-gray-200, #e5e7eb);
		background: var(--color-gray-50, #f9fafb);
		padding: 1.75rem;
		overflow: hidden;
	}

	.author-bio__inner {
		display: flex;
		gap: 1.25rem;
		align-items: flex-start;
	}

	.author-bio__avatar-wrap {
		flex-shrink: 0;
	}

	.author-bio__avatar {
		border-radius: 50%;
		object-fit: cover;
		object-position: center top;
		display: block;
		width: 80px;
		height: 80px;
		box-shadow:
			0 0 0 3px var(--color-gray-50, #f9fafb),
			0 0 0 5px color-mix(in srgb, var(--color-primary, #2563EB) 30%, transparent);
	}

	.author-bio__content {
		flex: 1;
		min-width: 0;
	}

	.author-bio__eyebrow {
		font-size: 0.7rem;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.08em;
		color: var(--color-text-tertiary, #9ca3af);
		margin: 0 0 0.2rem;
	}

	.author-bio__name {
		font-size: 1.05rem;
		font-weight: 700;
		color: var(--color-text-primary, #111827);
		margin: 0 0 0.5rem;
		line-height: 1.3;
	}

	.author-bio__text {
		font-size: 0.875rem;
		color: var(--color-text-secondary, #6b7280);
		margin: 0 0 1rem;
		line-height: 1.65;
	}

	.author-bio__links {
		display: flex;
		flex-wrap: wrap;
		gap: 0.5rem;
	}

	.author-bio__icon-btn {
		display: inline-flex;
		align-items: center;
		gap: 0.35rem;
		padding: 0.3rem 0.75rem 0.3rem 0.6rem;
		border-radius: 999px;
		border: 1px solid var(--color-gray-200, #e5e7eb);
		background: var(--color-white, #fff);
		color: var(--color-text-secondary, #6b7280);
		font-size: 0.8rem;
		font-weight: 500;
		text-decoration: none;
		transition: border-color 150ms ease, color 150ms ease, background 150ms ease;
	}

	.author-bio__icon-btn:hover {
		border-color: var(--color-primary, #2563EB);
		color: var(--color-primary, #2563EB);
		background: color-mix(in srgb, var(--color-primary, #2563EB) 5%, white);
	}

	@media (max-width: 520px) {
		.author-bio__inner {
			flex-direction: column;
			align-items: center;
			text-align: center;
		}

		.author-bio__links {
			justify-content: center;
		}
	}
</style>
