---
import { render, type CollectionEntry } from 'astro:content';

interface Props {
	experiences: CollectionEntry<'experience'>[];
}

const { experiences } = Astro.props;

function formatPeriod(start: Date, end?: Date) {
	const fmt = (d: Date) => d.toLocaleDateString('en-US', { month: 'short', year: 'numeric' });
	return `${fmt(start)} – ${end ? fmt(end) : 'Present'}`;
}
---

<section class="exp-section">
	<h2 class="section-title">Experience</h2>
	<ol class="exp-timeline">
		{await Promise.all(experiences.map(async (exp) => {
			const { Content } = await render(exp);
			const { role, company, location, startDate, endDate, stack } = exp.data;
			return (
				<li class="exp-item">
					<div class="exp-dot" aria-hidden="true"></div>
					<div class="exp-content">
						<div class="exp-header">
							<div class="exp-title-group">
								<p class="exp-role">{role}</p>
								<p class="exp-company">{company} · {location}</p>
							</div>
							<span class="exp-period">{formatPeriod(startDate, endDate)}</span>
						</div>
						<div class="exp-bullets">
							<Content />
						</div>
						<div class="exp-stack">
							{stack.map(t => <span class="tech-badge">{t}</span>)}
						</div>
					</div>
				</li>
			);
		}))}
	</ol>
</section>

<style>
	.exp-section {
		padding: var(--space-10) 0;
		border-top: 1px solid var(--color-border);
	}

	.exp-timeline {
		list-style: none;
		padding: 0;
		margin: 0;
		position: relative;
	}

	/* Vertical connecting line */
	.exp-timeline::before {
		content: '';
		position: absolute;
		left: 7px;
		top: 8px;
		bottom: 8px;
		width: 1px;
		background: var(--color-border);
	}

	.exp-item {
		display: flex;
		gap: var(--space-5);
		padding-bottom: var(--space-8);
		position: relative;
	}

	.exp-item:last-child {
		padding-bottom: 0;
	}

	/* Timeline dot */
	.exp-dot {
		flex-shrink: 0;
		width: 15px;
		height: 15px;
		border-radius: var(--radius-full);
		background: var(--color-surface-card);
		border: 2px solid var(--color-primary);
		margin-top: 4px;
		z-index: 1;
	}

	.exp-content {
		flex: 1;
		min-width: 0;
	}

	.exp-header {
		display: flex;
		align-items: flex-start;
		justify-content: space-between;
		gap: var(--space-3);
		flex-wrap: wrap;
		margin-bottom: var(--space-3);
	}

	.exp-title-group {
		min-width: 0;
	}

	.exp-role {
		font-size: var(--font-size-base);
		font-weight: var(--font-weight-bold);
		color: var(--color-text-primary);
		margin: 0 0 0.15rem;
		line-height: 1.3;
	}

	.exp-company {
		font-size: var(--font-size-sm);
		color: var(--color-primary);
		font-weight: var(--font-weight-medium);
		margin: 0;
	}

	.exp-period {
		font-size: var(--font-size-xs);
		color: var(--color-text-tertiary);
		font-weight: var(--font-weight-medium);
		white-space: nowrap;
		padding-top: 0.2rem;
	}

	/* Rendered markdown bullet list */
	.exp-bullets :global(ul) {
		margin: 0 0 var(--space-3) var(--space-4);
		padding: 0;
	}

	.exp-bullets :global(li) {
		font-size: var(--font-size-sm);
		color: var(--color-text-secondary);
		line-height: 1.65;
		margin-bottom: 0.3rem;
	}

	.exp-bullets :global(p) {
		font-size: var(--font-size-sm);
		color: var(--color-text-secondary);
		line-height: 1.65;
		margin: 0 0 var(--space-3);
	}

	.exp-stack {
		display: flex;
		flex-wrap: wrap;
		gap: 0.35rem;
	}

	@media (max-width: 640px) {
		.exp-header {
			flex-direction: column;
			gap: 0.15rem;
		}

		.exp-period {
			order: -1;
			padding-top: 0;
		}
	}
</style>
