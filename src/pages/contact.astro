---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { AUTHOR, CONTACT } from '../consts';
import '../styles/pages/contact.css';

const { subtitle, availabilityText, platforms } = CONTACT;
const { email, linkedin, github } = AUTHOR;
const socialPlatforms      = platforms.filter(p => p.group === 'social');
const freelancingPlatforms = platforms.filter(p => p.group === 'freelancing');
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead
			title={`Contact — ${AUTHOR.name}`}
			description={`Get in touch with ${AUTHOR.name} — ${AUTHOR.jobTitle} open to remote opportunities.`}
		/>
	</head>
	<body>
		<Header />
		<main class="contact-main">

			<div class="contact-page-header">
				<h1 class="contact-page-title">Get in Touch</h1>
				<p class="contact-page-subtitle">{subtitle}</p>
			</div>

			<!-- Group 1: Direct contact -->
			<div class="platform-group">
				<h2 class="platform-group__label">Direct contact</h2>
				<div class="platform-group__grid platform-group__grid--2">

					<a href={`mailto:${email}`} class="platform-card">
						<span class="platform-icon">
							<svg viewBox="0 0 24 24" width="20" height="20" fill="currentColor">
								<path d="M20 4H4c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4-8 5-8-5V6l8 5 8-5v2z"/>
							</svg>
						</span>
						<div class="platform-info">
							<span class="platform-name">Email</span>
							<span class="platform-handle">{email}</span>
						</div>
						<svg class="platform-arrow" viewBox="0 0 16 16" width="14" height="14">
							<path d="M3 8h10M8 3l5 5-5 5" stroke="currentColor" stroke-width="1.5" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
						</svg>
					</a>

					<a href={linkedin} target="_blank" rel="noopener" class="platform-card">
						<span class="platform-icon">
							<svg viewBox="0 0 24 24" width="20" height="20" fill="currentColor">
								<path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
							</svg>
						</span>
						<div class="platform-info">
							<span class="platform-name">LinkedIn</span>
							<span class="platform-handle">sidali-assoul</span>
						</div>
						<svg class="platform-arrow" viewBox="0 0 16 16" width="14" height="14">
							<path d="M3 8h10M8 3l5 5-5 5" stroke="currentColor" stroke-width="1.5" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
						</svg>
					</a>

				</div>
			</div>

			<!-- Group 2: Code -->
			<div class="platform-group">
				<h2 class="platform-group__label">Code</h2>
				<div class="platform-group__grid platform-group__grid--1">

					<a href={github} target="_blank" rel="noopener" class="platform-card">
						<span class="platform-icon">
							<svg viewBox="0 0 24 24" width="20" height="20" fill="currentColor">
								<path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/>
							</svg>
						</span>
						<div class="platform-info">
							<span class="platform-name">GitHub</span>
							<span class="platform-handle">stormsidali2001</span>
						</div>
						<svg class="platform-arrow" viewBox="0 0 16 16" width="14" height="14">
							<path d="M3 8h10M8 3l5 5-5 5" stroke="currentColor" stroke-width="1.5" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
						</svg>
					</a>

				</div>
			</div>

			<!-- Group 3: Social & Content -->
			<div class="platform-group">
				<h2 class="platform-group__label">Social & Content</h2>
				<div class="platform-group__grid platform-group__grid--2">
					{socialPlatforms.map(p => (
						<a href={p.url} target="_blank" rel="noopener" class="platform-card">
							<span class="platform-icon platform-icon--img">
								<img src={p.icon} alt={p.name} width="22" height="22" />
							</span>
							<div class="platform-info">
								<span class="platform-name">{p.name}</span>
								<span class="platform-handle">{p.handle}</span>
							</div>
							<svg class="platform-arrow" viewBox="0 0 16 16" width="14" height="14">
								<path d="M3 8h10M8 3l5 5-5 5" stroke="currentColor" stroke-width="1.5" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
							</svg>
						</a>
					))}
				</div>
			</div>

			<!-- Group 4: Freelancing platforms (from content collection) -->
			<div class="platform-group">
				<h2 class="platform-group__label">Freelancing platforms</h2>
				<div class="platform-group__grid platform-group__grid--2">

					{freelancingPlatforms.map(p => (
						<a href={p.url} target="_blank" rel="noopener" class="platform-card">
							<span class="platform-icon platform-icon--img">
								<img src={p.icon} alt={p.name} width="22" height="22" />
							</span>
							<div class="platform-info">
								<span class="platform-name">{p.name}</span>
								<span class="platform-handle">{p.handle}</span>
							</div>
							<svg class="platform-arrow" viewBox="0 0 16 16" width="14" height="14">
								<path d="M3 8h10M8 3l5 5-5 5" stroke="currentColor" stroke-width="1.5" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
							</svg>
						</a>
					))}

				</div>
			</div>

			<div class="availability-badge">
				<span class="availability-dot"></span>
				{availabilityText}
			</div>

		</main>
		<Footer />
	</body>
</html>
