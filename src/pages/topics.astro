---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_TITLE } from '../consts';
import '../styles/pages/topics.css';

const posts = await getCollection('blog');

// Build topic → count map, sorted by count descending
const topicMap = new Map<string, number>();
for (const post of posts) {
	for (const tag of post.data.tags ?? []) {
		topicMap.set(tag, (topicMap.get(tag) ?? 0) + 1);
	}
}
const topics = [...topicMap.entries()]
	.sort((a, b) => b[1] - a[1])
	.map(([name, count]) => ({ name, count }));
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead
			title={`Topics — ${SITE_TITLE}`}
			description="All the topics I write about — software engineering, distributed systems, AI microservices, and more."
		/>
	</head>
	<body>
		<Header />
		<main class="topics-main">

			<a href="/blog" class="topics-back-link">← Back to Blog</a>

			<div class="topics-page-header">
				<div class="topics-title-row">
					<h1 class="topics-page-title">Topics</h1>
					<span class="topics-count">{topics.length} topic{topics.length !== 1 ? 's' : ''}</span>
				</div>
				<p class="topics-page-subtitle">Everything I've written about — browse by topic to find what interests you.</p>
			</div>

			<h2 class="topics-section-label">All topics</h2>

			<div class="topics-grid">
				{topics.map(({ name, count }) => (
					<a href={`/blog?tag=${encodeURIComponent(name)}`} class="topic-card">
						<div class="topic-card__header">
							<span class="topic-card__hash">#</span>
							<span class="topic-card__count">{count} article{count !== 1 ? 's' : ''}</span>
						</div>
						<h2 class="topic-card__name">{name}</h2>
						<span class="topic-card__cta">View articles →</span>
					</a>
				))}
			</div>

		</main>
		<Footer />
	</body>
</html>
