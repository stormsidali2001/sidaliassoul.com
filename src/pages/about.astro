---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import '../styles/pages/about.css';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead
			title="About — Sidali Assoul"
			description="Full Stack Engineer with 4+ years building scalable SaaS platforms and AI microservices. Based in Algeria, open to remote opportunities."
		/>
	</head>
	<body>
		<Header />
		<main class="about-main">

			<div class="about-page-header">
				<h1 class="about-page-title">About Me</h1>
			</div>

			<!-- Summary -->
			<section class="about-section about-summary">
				<p>
					Full-stack engineer obsessed with understanding the core gist of your business before
					touching the keyboard. I build scalable SaaS platforms and AI microservices that stay
					stable in production — leveraging Clean Architecture, DDD, and high-performance engineering.
				</p>
				<p>
					I'm based in Béjaïa, Algeria and have 4+ years of experience delivering production
					systems for clients across Algeria, France, and the UAE. I'm currently open to
					full-time remote roles or international opportunities.
				</p>
				<div class="about-contact-row">
					<a href="mailto:assoulsidali@gmail.com" class="about-contact-link">assoulsidali@gmail.com</a>
					<span class="about-sep">·</span>
					<a href="https://linkedin.com/in/sidali-assoul" target="_blank" rel="noopener" class="about-contact-link">LinkedIn</a>
					<span class="about-sep">·</span>
					<a href="https://github.com/stormsidali2001" target="_blank" rel="noopener" class="about-contact-link">GitHub</a>
					<span class="about-sep">·</span>
					<span class="about-location">Béjaïa, Algeria</span>
				</div>
			</section>

			<!-- Experience -->
			<section class="about-section">
				<h2 class="about-section-heading">Experience</h2>

				<div class="about-timeline">

					<div class="about-timeline-item">
						<div class="timeline-dot"></div>
						<div class="timeline-content">
							<div class="timeline-header">
								<h3 class="timeline-role">Full Stack Engineer — Freelance</h3>
								<span class="timeline-period">Jan 2024 – Jan 2026</span>
							</div>
							<p class="timeline-company">Upwork Client · UAE (Remote)</p>
							<ul class="timeline-bullets">
								<li>Architected a multi-tenant logistics hub (110+ model schema) syncing Shopify & WooCommerce orders</li>
								<li>Led a developer team of 4, conducted technical interviews, and performed code reviews</li>
								<li>Implemented financial infrastructure with Stripe Connect for merchant wallets, withdrawals, and payouts</li>
							</ul>
							<div class="timeline-stack">
								<span class="tech-badge">Laravel 12</span>
								<span class="tech-badge">Next.js 15</span>
								<span class="tech-badge">TypeScript</span>
								<span class="tech-badge">Stripe</span>
							</div>
						</div>
					</div>

					<div class="about-timeline-item">
						<div class="timeline-dot"></div>
						<div class="timeline-content">
							<div class="timeline-header">
								<h3 class="timeline-role">Backend Engineer</h3>
								<span class="timeline-period">Apr 2023 – Nov 2023</span>
							</div>
							<p class="timeline-company">Addinfo · Paris, France (Remote)</p>
							<ul class="timeline-bullets">
								<li>Architected multi-tenant SaaS with high-throughput NestJS core and multi-provider OAuth</li>
								<li>Reduced analytics latency from ~3s to &lt;100ms via Materialized View strategy</li>
								<li>Launched standalone Certification Microservice with Stripe, LinkedIn OAuth, and PDF generation</li>
							</ul>
							<div class="timeline-stack">
								<span class="tech-badge">NestJS</span>
								<span class="tech-badge">PostgreSQL</span>
								<span class="tech-badge">Next.js</span>
								<span class="tech-badge">Docker</span>
							</div>
						</div>
					</div>

					<div class="about-timeline-item">
						<div class="timeline-dot"></div>
						<div class="timeline-content">
							<div class="timeline-header">
								<h3 class="timeline-role">Software Engineer</h3>
								<span class="timeline-period">Sep 2022 – Mar 2023</span>
							</div>
							<p class="timeline-company">CreaTech dz · Algiers, Algeria</p>
							<ul class="timeline-bullets">
								<li>Built a multi-tenant Events Marketplace with Twilio SMS-OTP, RBAC, and geo-tagged discovery</li>
								<li>Engineered a full revenue engine: Stripe payments, loyalty system, SaaS tier subscriptions</li>
								<li>Built LMS backend with tri-role identity, teacher availability mapping, and RxJS Zoom scheduler</li>
							</ul>
							<div class="timeline-stack">
								<span class="tech-badge">NestJS</span>
								<span class="tech-badge">MySQL</span>
								<span class="tech-badge">Stripe</span>
								<span class="tech-badge">Twilio</span>
							</div>
						</div>
					</div>

					<div class="about-timeline-item">
						<div class="timeline-dot"></div>
						<div class="timeline-content">
							<div class="timeline-header">
								<h3 class="timeline-role">Full Stack Engineer</h3>
								<span class="timeline-period">May 2022 – Aug 2022</span>
							</div>
							<p class="timeline-company">Data Intuition · Algiers, Algeria</p>
							<ul class="timeline-bullets">
								<li>Maintained and modernized three legacy production platforms built with Express.js and EJS</li>
								<li>Resolved security vulnerabilities in high-traffic administrative portals</li>
							</ul>
							<div class="timeline-stack">
								<span class="tech-badge">Express.js</span>
								<span class="tech-badge">Node.js</span>
							</div>
						</div>
					</div>

				</div>
			</section>

			<!-- Education -->
			<section class="about-section">
				<h2 class="about-section-heading">Education</h2>
				<div class="about-timeline">
					<div class="about-timeline-item">
						<div class="timeline-dot"></div>
						<div class="timeline-content">
							<div class="timeline-header">
								<h3 class="timeline-role">M.S. in Computer Science</h3>
								<span class="timeline-period">Sep 2019 – Sep 2024</span>
							</div>
							<p class="timeline-company">Higher School of Computer Science (ESI-SBA) · Sidi Bel Abbes, Algeria</p>
							<ul class="timeline-bullets">
								<li>
									<strong>Master's Thesis:</strong> Leveraging Gemini Pro and BERT for automated IMRaD classification.
									Engineered a 169k-sentence dataset and achieved 98.21% peak F1 by fine-tuning 4 hierarchical BERT models.
								</li>
								<li>Architected a scalable 7-node distributed system (Next.js, FastAPI, TF Serving, Eureka)</li>
							</ul>
						</div>
					</div>
				</div>
			</section>

		</main>
		<Footer />
	</body>
</html>
